{
  "_comment": "kit settings template (v4.0). permissions.allow ships ACTIVE with read-only commands so review/research subagents don't spam permission prompts — trim or extend to taste. Hooks ship ENABLED (v3.5+): to disable, rename 'hooks' to something else (e.g. '_hooks_disabled') and restart the session. Keep SessionStart and Stop TOGETHER — the Stop gate reads the baseline that SessionStart records; without it, committed changes are invisible to the gate. v4.0 adds protect-paths (no-touch-zone enforcement; user escape hatch: launch with KIT_PROTECT=off) and tool-breaker (retry-spiral circuit breaker + telemetry; KIT_BREAKER=off), registered under PreToolUse/PostToolUseFailure below.",

  "permissions": {
    "allow": [
      "Bash(timeout *)",
      "Bash(git status)",
      "Bash(git status *)",
      "Bash(git diff)",
      "Bash(git diff *)",
      "Bash(git log)",
      "Bash(git log *)",
      "Bash(git show *)",
      "Bash(ls)",
      "Bash(ls *)"
    ]
  },

  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Edit|MultiEdit|Write|NotebookEdit",
        "hooks": [
          {
            "type": "command",
            "command": "$CLAUDE_PROJECT_DIR/.claude/hooks/protect-paths.sh",
            "timeout": 5
          }
        ]
      },
      {
        "matcher": "*",
        "hooks": [
          {
            "type": "command",
            "command": "$CLAUDE_PROJECT_DIR/.claude/hooks/tool-breaker.sh",
            "timeout": 5
          }
        ]
      }
    ],
    "PostToolUseFailure": [
      {
        "matcher": "*",
        "hooks": [
          {
            "type": "command",
            "command": "$CLAUDE_PROJECT_DIR/.claude/hooks/tool-breaker.sh",
            "timeout": 5
          }
        ]
      }
    ],
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "$CLAUDE_PROJECT_DIR/.claude/hooks/session-start.sh",
            "timeout": 5
          }
        ]
      }
    ],
    "UserPromptSubmit": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "$CLAUDE_PROJECT_DIR/.claude/hooks/classify-task.sh",
            "timeout": 5
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "$CLAUDE_PROJECT_DIR/.claude/hooks/verify-final-review.sh",
            "timeout": 10
          }
        ]
      }
    ]
  }
}
