#!/usr/bin/env python3
"""proj — 跨專案 PROJECT.toml 彙總(kit v4.4)。

用法:
  proj              全專案總覽表格(狀態/說明/付費服務/最後 commit)
  proj <name>       單一專案完整資訊(起始指令可直接複製)
  proj money        只列有付費服務的專案,每服務一列
  proj remote       gh repo list 對照本機,列出未 clone 的 repo
  proj html         產出視覺化 HTML dashboard,WSL 自動開瀏覽器

掃描根目錄: $PROJ_ROOT(預設 $HOME)第一層子目錄中,有 .git 或
PROJECT.toml 者視為專案。Python 3.11+,零第三方依賴。
"""
import datetime
import html
import os
import shutil
import subprocess
import sys
import tomllib
import unicodedata
from pathlib import Path

# idle = 上線自走、無人開發、等訊號或新需求。與 active（有人正在動它）、
# paused（擱置，連跑都不跑了）、done（結案，不再動）都不同——它還活著、還在花錢。
VALID_STATUSES = {"active", "mvp", "idle", "done", "paused", "abandoned"}
STALE_DAYS = 30
# status_note 每段字數上限。基準：life-tracker 的 27|25 字就足以說清楚進度與下一步。
NOTE_SEG_MAX = 60
# service 名稱上限。基準：「Google Cloud Storage」20 字,已是最長的真實服務名。
SERVICE_MAX = 24
# billing 是封閉枚舉——_paid_bucket() 對認不得的值一律當「按用量」,所以一個
# 自由發揮的值（"訂閱制"）會讓固定月費**靜默掉進錯的桶子**,在花錢總覽裡消失。
VALID_BILLING = {"按用量", "月費", "年費", "free-tier"}
# monthly_est 字數上限。只放金額與用量（"NT$128/月;Actions 用量估 2000+ 分/月"）——
# 怎麼算出來的、確認日期、月上限設定,全歸 TOML 註解。表格欄位不是註腳。
MONTHLY_EST_MAX = 40


def warn(msg):
    print(f"proj: {msg}", file=sys.stderr)


def find_projects(root):
    try:
        entries = sorted(root.iterdir())
    except OSError as e:
        warn(f"無法讀取 {root}: {e}")
        return []
    return [d for d in entries
            if d.is_dir() and not d.name.startswith(".")
            and ((d / ".git").exists() or (d / "PROJECT.toml").is_file())]


def load_manifest(d):
    """回傳 (data, err): 無檔 (None, None);壞檔 (None, str);正常 (dict, None)。"""
    p = d / "PROJECT.toml"
    if not p.is_file():
        return None, None
    try:
        with open(p, "rb") as f:
            data = tomllib.load(f)
    except (tomllib.TOMLDecodeError, OSError) as e:
        return None, str(e)
    status = data.get("status")
    if status is not None and (not isinstance(status, str)
                               or status not in VALID_STATUSES):
        warn(f'{d.name}: status "{status}" 不在 {sorted(VALID_STATUSES)},照列')

    # status_note 的形狀檢查。規則（rules/project-manifest.md）本來就寫著「固定兩段、
    # 以分號隔開,細節歸 LESSONS / commit message」,但 2026-07-13 實測 12 個專案有 11 個
    # 違反——全靠模型自律的規則不會被遵守,因為每次都覺得「這個細節很重要」。
    # 這裡不擋、只吵：dashboard 是拿來掃一眼的,一段 60 字以上就不是「一句話」了。
    note = data.get("status_note")
    if isinstance(note, str) and note:
        segs = note.split(";")
        if len(segs) != 2:
            warn(f"{d.name}: status_note 應為「目前進度;下一步」兩段,實際 {len(segs)} 段")
        for i, s in enumerate(segs):
            if len(s) > NOTE_SEG_MAX:
                warn(f"{d.name}: status_note 第 {i+1} 段 {len(s)} 字 "
                     f"(上限 {NOTE_SEG_MAX})——細節歸 LESSONS / commit message")

    # service 只放**服務名稱**,不放說明。括號幾乎必然是說明（"Supabase (PostgreSQL)"、
    # "GitHub Pro（repo 已轉 private → ...）"）,而 badge 是拿來一眼認出服務的,不是拿來讀的。
    # 說明降級成 TOML 註解,或寫進 monthly_est / cancel——那裡本來就該有。
    for p in data.get("paid", []):
        s = p.get("service")
        if not isinstance(s, str) or not s:
            continue
        if "(" in s or "（" in s:
            warn(f'{d.name}: service "{s}" 含括號說明——只放服務名,說明歸註解')
        elif len(s) > SERVICE_MAX:
            warn(f'{d.name}: service "{s}" {len(s)} 字(上限 {SERVICE_MAX})——只放服務名')
        b = p.get("billing")
        if b is not None and b not in VALID_BILLING:
            warn(f'{d.name}: {s} 的 billing "{b}" 不在 {sorted(VALID_BILLING)}'
                 f'——會被當成「按用量」,固定月費就從花錢總覽消失了')
        m = p.get("monthly_est")
        if isinstance(m, str) and len(m) > MONTHLY_EST_MAX:
            warn(f"{d.name}: {s} 的 monthly_est {len(m)} 字(上限 {MONTHLY_EST_MAX})"
                 f"——只放金額與用量,算法與依據歸註解")
    return data, None


def last_commit_date(d):
    if not (d / ".git").exists():
        return None
    try:
        r = subprocess.run(["git", "-C", str(d), "log", "-1", "--format=%cs"],
                           capture_output=True, text=True, timeout=10)
    except (OSError, subprocess.TimeoutExpired):
        return None
    try:
        return datetime.date.fromisoformat(r.stdout.strip())
    except ValueError:
        return None


def is_stale(data, commit_date):
    upd = data.get("updated")
    if isinstance(upd, datetime.datetime):
        upd = upd.date()
    if not isinstance(upd, datetime.date) or commit_date is None:
        return False
    return (commit_date - upd).days > STALE_DAYS


# --- 等寬表格(CJK 全形字算 2 格,不然中文欄位會歪) ---

def disp_width(s):
    return sum(2 if unicodedata.east_asian_width(c) in ("W", "F") else 1
               for c in s)


def pad(s, width):
    return s + " " * (width - disp_width(s))


def print_table(headers, rows):
    widths = [disp_width(h) for h in headers]
    for r in rows:
        for i, cell in enumerate(r):
            widths[i] = max(widths[i], disp_width(cell))

    def emit(cells):
        print("  ".join(pad(cells[i], widths[i])
                        for i in range(len(cells))).rstrip())

    emit(headers)
    emit(["-" * w for w in widths])
    for r in rows:
        emit(r)


def paid_summary(data):
    parts = []
    for p in data.get("paid", []):
        name = str(p.get("service", "?"))
        if str(p.get("billing", "")) != "free-tier":
            name = "$" + name
        parts.append(name)
    return ", ".join(parts)


def cmd_list(root):
    rows = []
    for d in find_projects(root):
        data, err = load_manifest(d)
        cdate = last_commit_date(d)
        cstr = cdate.isoformat() if cdate else "-"
        if err:
            warn(f"{d.name}/PROJECT.toml 解析失敗: {err}")
            rows.append([d.name, "manifest 損壞", "", "", cstr])
        elif data is None:
            rows.append([d.name, "未登記", "", "", cstr])
        else:
            status = str(data.get("status", "?"))
            if is_stale(data, cdate):
                status += " ⚠"
            rows.append([d.name, status, str(data.get("status_note", "")),
                         paid_summary(data), cstr])
    print_table(["專案", "狀態", "說明", "付費服務", "最後 commit"], rows)
    return 0


def cmd_detail(root, name):
    d = root / name
    if not d.is_dir():
        warn(f"找不到專案目錄 {d}")
        return 1
    data, err = load_manifest(d)
    if err:
        warn(f"{name}/PROJECT.toml 解析失敗: {err}")
        return 1
    if data is None:
        warn(f"{name} 沒有 PROJECT.toml(未登記)")
        return 1
    cdate = last_commit_date(d)
    stale = "  ⚠ manifest 可能過時" if is_stale(data, cdate) else ""
    print(f"{data.get('name', name)}  [{data.get('status', '?')}]{stale}")
    if data.get("status_note"):
        print(data["status_note"])
    print(f"updated: {data.get('updated', '?')}   "
          f"最後 commit: {cdate.isoformat() if cdate else '-'}")
    if data.get("commands"):
        print("\n指令:")
        for k, v in data["commands"].items():
            print(f"  {k}:")
            print(f"    {v}")
    paid = data.get("paid", [])
    if paid:
        print("\n付費服務:")
        for p in paid:
            print(f"  - {p.get('service', '?')} | {p.get('billing', '?')}"
                  f" | {p.get('monthly_est', '?')}")
            if p.get("cancel"):
                print(f"    取消方式: {p['cancel']}")
    else:
        print("\n付費服務: 無")
    return 0


def cmd_money(root):
    rows = []
    for d in find_projects(root):
        data, _ = load_manifest(d)
        if not data:
            continue
        for p in data.get("paid", []):
            rows.append([d.name, str(p.get("service", "?")),
                         str(p.get("billing", "?")),
                         str(p.get("monthly_est", "?")),
                         str(p.get("cancel", ""))])
    if not rows:
        print("沒有登記任何付費服務。")
        return 0
    print_table(["專案", "服務", "計費", "月費估計", "取消方式"], rows)
    return 0


def cmd_remote(root):
    if shutil.which("gh") is None:
        warn("需要 gh CLI(安裝後 gh auth login)")
        return 1
    r = subprocess.run(
        ["gh", "repo", "list", "--json", "name,updatedAt", "--limit", "200"],
        capture_output=True, text=True)
    if r.returncode != 0:
        warn(f"gh repo list 失敗: {r.stderr.strip()}")
        return 1
    import json
    repos = json.loads(r.stdout)
    local = {d.name for d in find_projects(root)}
    rows = [[x["name"], x.get("updatedAt", "")[:10]]
            for x in sorted(repos, key=lambda x: x["name"])
            if x["name"] not in local]
    if not rows:
        print("GitHub 上所有 repo 都已 clone。")
        return 0
    print_table(["未 clone 的 repo", "最後更新"], rows)
    return 0


# --- proj html: 自包含 HTML dashboard ---

