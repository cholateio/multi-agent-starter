_JS = """
document.querySelectorAll('.kpi-status').forEach(function(b){b.addEventListener('click',function(){var f=b.dataset.filter;var on=b.classList.toggle('active');document.querySelectorAll('.kpi-status').forEach(function(x){if(x!==b)x.classList.remove('active')});document.querySelectorAll('.card').forEach(function(c){c.style.display=(!on||c.dataset.status===f)?'':'none'})})});
document.querySelectorAll('.copy').forEach(function(b){b.addEventListener('click',function(){if(navigator.clipboard)navigator.clipboard.writeText(b.dataset.cmd);var t=b.textContent;b.textContent='OK';setTimeout(function(){b.textContent=t},900)})});
"""


def _e(s):
    return html.escape(str(s), quote=True)


def _collect(root):
    rows = []
    for d in find_projects(root):
        data, err = load_manifest(d)
        cdate = last_commit_date(d)
        cstr = cdate.isoformat() if cdate else "-"
        if err:
            rows.append({"name": d.name, "status": "manifest 損壞", "skey": "broken",
                         "note": "", "commands": {}, "paid": [], "commit": cstr, "stale": False})
        elif data is None:
            rows.append({"name": d.name, "status": "未登記", "skey": "unregistered",
                         "note": "", "commands": {}, "paid": [], "commit": cstr, "stale": False})
        else:
            st = str(data.get("status", "?"))
            rows.append({
                "name": str(data.get("name", d.name)),
                "status": st,
                "skey": st if st in STATUS_ORDER else "unregistered",
                "note": str(data.get("status_note", "")),
                "commands": {str(k): str(v) for k, v in (data.get("commands") or {}).items()},
                "paid": data.get("paid", []),
                "commit": cstr,
                "stale": is_stale(data, cdate),
            })
    return rows


def _paid_bucket(billing):
    if billing in ("月費", "年費"):
        return "fixed"
    if billing == "free-tier":
        return "free"
    return "usage"


def _render_kpi(rows):
    counts = {}
    for r in rows:
        counts[r["skey"]] = counts.get(r["skey"], 0) + 1
    fixed = usage = 0
    for r in rows:
        for p in r["paid"]:
            b = _paid_bucket(str(p.get("billing", "")))
            if b == "fixed":
                fixed += 1
            elif b == "usage":
                usage += 1
    tiles = [f'<div class="kpi"><span class="kpi-n">{len(rows)}</span><span class="kpi-l">專案</span></div>']
    for st in STATUS_ORDER:
        n = counts.get(st)
        if n:
            tiles.append(
                f'<button class="kpi kpi-status" data-filter="{_e(st)}">'
                f'<span class="kpi-n">{n}</span>'
                f'<span class="kpi-l"><span class="dot" data-status="{_e(st)}"></span>{_e(st)}</span></button>')
    tiles.append(f'<div class="kpi"><span class="kpi-n">{fixed}</span><span class="kpi-l">固定月費項</span></div>')
    tiles.append(f'<div class="kpi kpi-warn"><span class="kpi-n">{usage}</span><span class="kpi-l">按用量待盯</span></div>')
    return '<section class="kpis">' + "".join(tiles) + '</section>'


def _render_note(note):
    if not note:
        return ''
    parts = [s.strip() for s in note.replace("；", ";").split(";") if s.strip()]
    if len(parts) <= 1:
        return f'<p class="note">{_e(note)}</p>'
    items = "".join(f'<li>{_e(p)}</li>' for p in parts)
    return f'<ul class="note-list">{items}</ul>'


def _render_cards(rows):
    cards = []
    for r in rows:
        badge = f'<span class="badge" data-status="{_e(r["skey"])}">{_e(r["status"])}</span>'
        stale = '<span class="stale" title="manifest 可能過時">⚠</span>' if r["stale"] else ''
        note = _render_note(r["note"])
        # 收錄規範在 manifest schema 端執法(kit rule:只收「用它」的指令),
        # 渲染端不做啟發式過濾——manifest 有什麼顯什麼
        cmds = ''
        if r["commands"]:
            items = "".join(
                f'<li><span class="cmd-k">{_e(k)}</span><code>{_e(v)}</code>'
                f'<button class="copy" data-cmd="{_e(v)}" title="複製">C</button></li>'
                for k, v in r["commands"].items())
            cmds = f'<ul class="cmds">{items}</ul>'
        paid = ''
        if r["paid"]:
            tags = "".join(
                f'<span class="paid paid-{_paid_bucket(str(p.get("billing", "")))}">'
                f'{_e(p.get("service", "?"))}</span>'
                for p in r["paid"])
            paid = f'<div class="paid-row">{tags}</div>'
        cards.append(
            f'<article class="card" data-status="{_e(r["skey"])}">'
            f'<div class="c-head"><div class="c-badge">{badge}{stale}</div>'
            f'<h3>{_e(r["name"])}</h3>'
            f'<span class="commit">{_e(r["commit"])}</span></div>'
            f'<div class="c-body">{note}{cmds}{paid}</div></article>')
    return '<section class="cards">' + "".join(cards) + '</section>'


def _render_money(rows):
    fixed, usage, free = [], [], []
    for r in rows:
        for p in r["paid"]:
            entry = (r["name"], p)
            b = _paid_bucket(str(p.get("billing", "")))
            (fixed if b == "fixed" else free if b == "free" else usage).append(entry)
    if not (fixed or usage or free):
        return ''

    def table(items, cls="", with_billing=True):
        # 按用量組不渲染「計費」欄——那欄恆為「按用量」,組標題已言明。但**月費估計要顯示**:
        # 原本連它一起藏掉,理由是「估計恆為 ?」——那個假設 2026-07-13 失效了(case-pick 的
        # Gemini 有實測的 ~NT$200/月)。按用量正是最該盯的一組,把唯一的金額欄藏起來,
        # 等於讓「待盯」變成「看不到」。
        #
        # **cancel 不渲染**:dashboard 是「這個月花多少」的掃視面板,不是操作手冊。取消步驟
        # 又長又只在真的要停用時才需要——那時去看 `proj money`(終端)或 PROJECT.toml。
        def cells(name, p):
            row = [_e(name), _e(p.get("service", "?"))]
            if with_billing:
                row.append(_e(p.get("billing", "?")))
            row.append(_e(p.get("monthly_est", "?")))
            return "".join(f'<td>{c}</td>' for c in row)
        heads = ["專案", "服務"] + (["計費"] if with_billing else []) + ["月費估計"]
        body = "".join(f'<tr>{cells(name, p)}</tr>' for name, p in items)
        return (f'<table class="{cls}"><thead><tr>'
                + "".join(f'<th>{h}</th>' for h in heads)
                + f'</tr></thead><tbody>{body}</tbody></table>')

    parts = ['<h2>花錢總覽</h2>']
    if fixed:
        parts.append('<p class="grp">固定月費 / 年費</p>' + table(fixed))
    if usage:
        parts.append('<p class="grp warn">按用量待盯</p>'
                     + table(usage, "money-usage", with_billing=False))
    if free:
        parts.append(f'<details><summary>free-tier（$0，{len(free)} 項）</summary>'
                     f'{table(free)}</details>')
    return '<section class="money">' + "".join(parts) + '</section>'


def _render_html(rows):
    return (
        '<!doctype html><html lang="zh-Hant"><head><meta charset="utf-8">'
        '<meta name="viewport" content="width=device-width, initial-scale=1">'
        '<title>proj dashboard</title><style>' + _CSS + '</style></head><body>'
        '<h1>專案總覽</h1>'
        + _render_kpi(rows) + _render_cards(rows) + _render_money(rows)
        + '<script>' + _JS + '</script></body></html>')


def _open_in_browser(path):
    print(f"dashboard: {path}", file=sys.stderr)
    exe = shutil.which("explorer.exe")
    if exe is None:
        return
    try:
        r = subprocess.run(["wslpath", "-w", str(path)],
                           capture_output=True, text=True, timeout=5)
        win = r.stdout.strip() if r.returncode == 0 else ""
    except (OSError, subprocess.TimeoutExpired):
        win = ""
    if not win:
        return
    try:
        subprocess.run([exe, win], timeout=10)
    except (OSError, subprocess.TimeoutExpired):
        pass


def cmd_html(root):
    rows = _collect(root)
    out = Path.home() / ".local" / "share" / "proj" / "dashboard.html"
    try:
        out.parent.mkdir(parents=True, exist_ok=True)
        out.write_text(_render_html(rows), encoding="utf-8")
    except OSError as e:
        warn(f"無法寫入 {out}: {e}")
        return 1
    _open_in_browser(out)
    return 0


def main(argv):
    root = Path(os.environ.get("PROJ_ROOT", str(Path.home())))
    if len(argv) <= 1:
        return cmd_list(root)
    arg = argv[1]
    if arg in ("-h", "--help"):
        print(__doc__.strip())
        return 0
    if arg == "money":
        return cmd_money(root)
    if arg == "remote":
        return cmd_remote(root)
    if arg == "html":
        return cmd_html(root)
    return cmd_detail(root, arg)


if __name__ == "__main__":
    sys.exit(main(sys.argv))
